}
/* marquee strip */
.marquee-strip{
  position:relative;z-index:2;display:flex;align-items:center;gap:26px;
  padding:18px 5.5vw;border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  background:rgba(21,10,16,0.4);overflow:hidden;
}
.marquee-label{
  font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-faint);
  flex-shrink:0;padding-right:20px;border-right:1px solid var(--line-strong);white-space:nowrap;
}
.marquee-track{display:flex;overflow:hidden;flex:1;-webkit-mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);}
.marquee-group{display:inline-flex;align-items:center;gap:22px;white-space:nowrap;animation:marquee-scroll 32s linear infinite;}
.marquee-group span{font-family:var(--font-display);font-size:15px;color:var(--ink-dim);letter-spacing:0.01em;}
.marquee-group span.sep{color:var(--gold);font-size:11px;opacity:0.7;}
@keyframes marquee-scroll{from{transform:translateX(0);}to{transform:translateX(-100%);}}
@media(prefers-reduced-motion:reduce){.marquee-group{animation:none;}}
@media(max-width:700px){.marquee-label{display:none;}}

.scroll-cue{position:absolute;bottom:26px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:10px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--ink-faint);z-index:3;}
.scroll-cue .stick{width:1px;height:34px;background:linear-gradient(180deg,var(--gold),transparent);animation:cue 1.8s ease-in-out infinite;}

.next-arrow{
  position:fixed;left:50%;bottom:28px;transform:translateX(-50%);z-index:48;
  width:46px;height:46px;border-radius:50%;
  border:1px solid var(--line-strong);
  background:rgba(11,8,9,0.55);backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;
  transition:opacity 0.4s, border-color 0.3s, background 0.3s, transform 0.3s;
  opacity:0.85;
}
.next-arrow:hover{border-color:var(--gold);background:rgba(205,164,63,0.12);transform:translateX(-50%) translateY(-3px);}
.next-arrow svg{width:16px;height:16px;animation:next-arrow-bob 2.2s ease-in-out infinite;}
.next-arrow.hidden{opacity:0;pointer-events:none;transform:translateX(-50%) translateY(10px);}
@keyframes next-arrow-bob{0%,100%{transform:translateY(0);}50%{transform:translateY(4px);}}
@media(max-width:760px){.next-arrow{width:40px;height:40px;bottom:18px;}}
@keyframes cue{0%{opacity:0.2;}50%{opacity:1;}100%{opacity:0.2;}}
@media(max-width:900px){.hero-inner{grid-template-columns:1fr;}.hero-visual{order:-1;max-width:320px;margin:0 auto 20px;}.hero{padding-top:120px;}}

/* ============ TIMELINE (Legacy) ============ */
.future-row{display:flex;justify-content:space-between;position:relative;margin-top:64px;padding-top:8px;}
.future-row::before{
  content:'';position:absolute;top:14px;left:4%;right:4%;height:1px;background:var(--line);
}
.future-row::after{
  content:'';position:absolute;top:14px;left:4%;height:1px;background:linear-gradient(90deg,var(--gold),var(--gold-bright));
  width:0%;transition:width 1.8s cubic-bezier(.16,1,.3,1);
}
.future-row.in-view::after{width:92%;}
.future-node{position:relative;flex:1;text-align:center;opacity:0.35;transition:opacity 0.6s ease;}
.future-row.in-view .future-node{opacity:1;}
.future-node.current{opacity:1;}
.future-dot{
  width:15px;height:15px;border-radius:50%;margin:0 auto 18px;position:relative;z-index:2;
  background:var(--bg);border:2px solid var(--line-strong);transition:all 0.5s ease;
}
.future-row.in-view .future-node .future-dot{background:radial-gradient(circle at 35% 30%,var(--gold-bright),var(--gold) 70%);border-color:var(--gold-bright);box-shadow:0 0 14px rgba(240,207,122,0.5);}
.future-year{font-family:var(--font-display);font-size:22px;color:var(--ink);}
.future-node.current .future-year{color:var(--gold-bright);}
.future-tag{font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.05em;color:var(--ink-faint);margin-top:8px;}
@media(max-width:760px){
  .future-row{flex-direction:column;gap:26px;}
  .future-row::before,.future-row::after{display:none;}
  .future-node{text-align:left;display:flex;align-items:center;gap:16px;}
  .future-dot{margin:0;}
}

.timeline{position:relative;margin-top:56px;padding-left:6px;}
.timeline::before{content:'';position:absolute;left:24px;top:6px;bottom:6px;width:1px;background:var(--line);}
.timeline::after{
  content:'';position:absolute;left:24px;top:6px;width:1px;height:0%;
  background:linear-gradient(180deg,var(--gold-bright),var(--gold));
  box-shadow:0 0 8px rgba(240,207,122,0.5);
  transition:height 1.6s cubic-bezier(.16,1,.3,1);
}
.timeline.in-view::after{height:calc(100% - 12px);}
.tl-item{position:relative;padding-left:64px;margin-bottom:34px;opacity:0.4;transition:opacity 0.6s ease;}
.tl-item:last-child{margin-bottom:0;}
.timeline.in-view .tl-item{opacity:1;}
.tl-dot{
  position:absolute;left:15px;top:2px;width:19px;height:19px;border-radius:50%;
  background:var(--bg-2);border:1px solid var(--line-strong);
  box-shadow:0 0 0 4px rgba(11,8,9,1);
  transition:background 0.5s ease, box-shadow 0.5s ease, border-color 0.5s ease;
}
.timeline.in-view .tl-dot{
  background:radial-gradient(circle at 35% 30%,var(--gold-bright),var(--gold) 70%);
  border-color:transparent;
  box-shadow:0 0 0 4px rgba(11,8,9,1), 0 0 18px rgba(205,164,63,0.5);
}
.tl-year{font-family:var(--font-mono);font-size:12.5px;color:var(--gold-bright);letter-spacing:0.08em;}
.tl-item h4{font-family:var(--font-display);font-size:19px;font-weight:500;margin:6px 0 8px;}
.tl-item p{font-size:14.3px;color:var(--ink-dim);line-height:1.7;max-width:520px;}

.legacy-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;margin-top:50px;align-items:start;}
.anecdote-card{
  border:1px solid var(--line-strong);padding:30px 28px;background:linear-gradient(155deg,var(--bg-3),var(--bg-2));
  box-shadow:0 30px 60px -34px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.04);
  transform-style:preserve-3d;transition:transform 0.25s ease-out;
}
.anecdote-card .quote-mark{font-family:var(--font-display);font-style:italic;font-size:40px;color:var(--gold);line-height:0.6;}
.anecdote-card p{font-family:var(--font-display);font-style:italic;font-size:19px;line-height:1.55;color:var(--ink);margin:14px 0 16px;}
.anecdote-card .src{font-family:var(--font-mono);font-size:11px;color:var(--ink-faint);letter-spacing:0.06em;text-transform:uppercase;}

@media(max-width:860px){.legacy-grid{grid-template-columns:1fr;}}

