<div class="intro-overlay" id="introOverlay">
  <div class="intro-grain"></div>
  <div class="intro-beam"></div>
  <div class="intro-dust" id="introDust"></div>
  <div class="intro-stage" id="introStage">
    <div class="intro-flare" id="introFlare"></div>
    <div class="intro-flare-ray" id="introFlareRayL" style="transform:translate(-50%,-50%) rotate(20deg);"></div>
    <div class="intro-flare-ray" id="introFlareRayR" style="transform:translate(-50%,-50%) rotate(-20deg);"></div>
    <div class="intro-year" id="introYear"></div>
    <div class="intro-final" id="introFinal">
      <div class="intro-final-glow"></div>
      <div class="intro-final-shimmer"></div>
      <div class="intro-final-mark gold-emboss">Cinema රූ ස්වර</div>
      <div class="intro-final-sub">Where cinema meets music</div>
    </div>
  </div>
  <button class="intro-skip" id="introSkip">Skip intro</button>
</div>

<script>
(function(){
  var overlay = document.getElementById('introOverlay');
  var stage = document.getElementById('introStage');
  var yearEl = document.getElementById('introYear');
  var finalEl = document.getElementById('introFinal');
  var flareEl = document.getElementById('introFlare');
  var rayL = document.getElementById('introFlareRayL');
  var rayR = document.getElementById('introFlareRayR');
  var skipBtn = document.getElementById('introSkip');
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var years = ['1949','1956','1970','1995','2026'];
  var seenIntro = false;
  try{ seenIntro = sessionStorage.getItem('cinemaRuGiIntroSeen') === '1'; }catch(e){}

  document.body.classList.add('intro-active');

  function finish(){
    overlay.classList.add('done');
    document.body.classList.remove('intro-active');
    try{ sessionStorage.setItem('cinemaRuGiIntroSeen','1'); }catch(e){}
  }

  if(reduced || seenIntro){
    finish();
    return;
  }

  var timers = [];
  function at(ms, fn){ timers.push(setTimeout(fn, ms)); }
  function pulseFlare(){
    flareEl.classList.remove('pulse');
    void flareEl.offsetWidth;
    flareEl.classList.add('pulse');
    setTimeout(function(){ flareEl.classList.remove('pulse'); }, 650);
  }

  at(200, function(){ overlay.classList.add('zoom'); });

  var stepDuration = 1500;
  years.forEach(function(y, i){
    var start = 650 + i * stepDuration;
    at(start, function(){
      yearEl.textContent = y;
      yearEl.classList.remove('leaving');
      yearEl.classList.add('show');
      if(i > 0){ pulseFlare(); }
    });
    at(start + stepDuration - 420, function(){
      yearEl.classList.remove('show');
      yearEl.classList.add('leaving');
    });
  });

  var flareTime = 650 + years.length * stepDuration + 150;
  at(flareTime, function(){
    flareEl.classList.remove('pulse');
    flareEl.classList.add('show');
    rayL.classList.add('show');
    rayR.classList.add('show');
  });

  var finalTime = flareTime + 1000;
  at(finalTime, function(){ finalEl.classList.add('show'); });

  at(finalTime + 3200, finish);

  skipBtn.addEventListener('click', function(){
    timers.forEach(clearTimeout);
    finish();
  });
})();
</script>

