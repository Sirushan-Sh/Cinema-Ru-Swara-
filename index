/* ============ EMOTIONAL INTERLUDE ============ */
.interlude{background:#000;border-top-color:transparent;overflow:hidden;}
.interlude .chapter-stage{display:flex;align-items:center;justify-content:center;overflow:visible;position:relative;}
.interlude-particles{position:absolute;inset:0;pointer-events:none;overflow:hidden;opacity:0;transition:opacity 2s ease;}
.interlude.in-view .interlude-particles{opacity:0.5;}
.interlude-particles::before{
  content:'';position:absolute;width:100%;height:100%;
  background-image:
    radial-gradient(1.4px 1.4px at 15% 25%, rgba(240,207,122,0.45), transparent),
    radial-gradient(1px 1px at 75% 65%, rgba(240,207,122,0.35), transparent),
    radial-gradient(1.4px 1.4px at 40% 78%, rgba(240,207,122,0.3), transparent),
    radial-gradient(1px 1px at 88% 30%, rgba(240,207,122,0.35), transparent),
    radial-gradient(1.4px 1.4px at 8% 60%, rgba(240,207,122,0.3), transparent);
  animation:dust-drift 22s linear infinite;
}
.interlude-sweep{
  position:absolute;top:0;bottom:0;width:40%;left:-40%;pointer-events:none;
  background:linear-gradient(100deg,transparent,rgba(240,207,122,0.05) 45%,rgba(240,207,122,0.09) 50%,rgba(240,207,122,0.05) 55%,transparent);
  opacity:0;
}
.interlude.in-view .interlude-sweep{animation:interlude-sweep-move 7s cubic-bezier(.4,0,.2,1) 0.6s infinite;}
@keyframes interlude-sweep-move{0%{opacity:0;left:-40%;}8%{opacity:1;}45%{opacity:1;}60%{opacity:0;left:120%;}100%{opacity:0;left:120%;}}
.interlude-lines{
  position:relative;
  width:min(92vw,1100px);
  height:clamp(70px,10vw,130px);
  text-align:center;
  perspective:800px;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}
.interlude-line{
  font-family:var(--font-display);font-weight:400;font-style:italic;
  font-size:clamp(24px,3.6vw,44px);color:var(--ink-dim);
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  width:100%;max-width:100%;padding:0 3vw;
  opacity:0;visibility:hidden;filter:blur(8px);
  transform:translateY(18px) scale(0.97);
  transition:
    opacity .95s cubic-bezier(.22,1,.36,1),
    transform 1.05s cubic-bezier(.22,1,.36,1),
    filter .95s ease,
    visibility 0s linear 1.05s;
  will-change:opacity,transform,filter;
  white-space:normal;
  line-height:1.2;
}
.interlude-line.active{
  opacity:1;visibility:visible;filter:blur(0);
  transform:translateY(0) scale(1);
  transition-delay:0s;
}
.interlude-line.exit{
  opacity:0;visibility:hidden;filter:blur(9px);
  transform:translateY(-18px) scale(1.02);
  transition:
    opacity .75s cubic-bezier(.4,0,1,1),
    transform .85s cubic-bezier(.4,0,1,1),
    filter .75s ease,
    visibility 0s linear .85s;
}
.interlude-line[data-line="3"]{font-style:normal;font-weight:500;}
@media(max-width:700px){
  .interlude-lines{height:clamp(92px,24vw,150px);}
  .interlude-line{font-size:clamp(22px,7vw,34px);padding:0 7vw;}
}

