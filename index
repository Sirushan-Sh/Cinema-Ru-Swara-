<script>
(function(){
  var nav = document.getElementById('nav');
  var progress = document.getElementById('progress');
  var chapters = Array.prototype.slice.call(document.querySelectorAll('.chapter'));
  var chapterIndex = document.getElementById('chapterIndex');
  var dotLinks = Array.prototype.slice.call(document.querySelectorAll('.dot-nav a'));
  var portalR1 = document.getElementById('portalR1');
  var portalR2 = document.getElementById('portalR2');
  var nextArrow = document.getElementById('nextArrow');
  var currentChapterIdx = 0;
  var ticking = false;

  function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }

  function update(){
    ticking = false;
    var h = document.documentElement;
    var scrollTop = h.scrollTop || document.body.scrollTop;
    var vh = window.innerHeight;
    var pct = scrollTop / (h.scrollHeight - h.clientHeight) * 100;
    progress.style.width = pct + '%';
    nav.classList.toggle('scrolled', scrollTop > 20);

    var closestIdx = 0, closestDist = Infinity, closestProgress = 0;

    chapters.forEach(function(ch, i){
      var rect = ch.getBoundingClientRect();
      var center = rect.top + rect.height/2 - vh/2;
      var raw = center / vh;
      var p = clamp(raw, -1, 1);
      var stage = ch.querySelector('.chapter-stage');
      if(stage){
        var ty = p * 70;
        var scale = 1 - Math.abs(p) * 0.08;
        var opacity = 1 - Math.abs(p) * 0.75;
        var blur = Math.min(3, Math.abs(p) * 4);
        stage.style.transform = 'translateY(' + ty + 'px) scale(' + scale + ')';
        stage.style.opacity = Math.max(0, opacity);
        stage.style.filter = blur > 0.05 ? 'blur(' + blur.toFixed(1) + 'px)' : 'none';
      }
      var dist = Math.abs(raw);
      if(dist < closestDist){ closestDist = dist; closestIdx = i; closestProgress = raw; }
    });

    var active = chapters[closestIdx];
    if(active){
      currentChapterIdx = closestIdx;
      chapterIndex.innerHTML = '<span class="num">' + String(closestIdx+1).padStart(2,'0') + '</span><span>/ ' + chapters.length + ' — ' + active.getAttribute('data-chapter') + '</span>';
      dotLinks.forEach(function(d,i){ d.classList.toggle('active', i === closestIdx); });
      nextArrow.classList.toggle('hidden', closestIdx >= chapters.length - 1);

      var ringP = clamp(1 - Math.abs(closestProgress) * 1.4, 0, 1);
      var s1 = 0.75 + ringP * 0.35;
      var s2 = 0.8 + ringP * 0.4;
      portalR1.style.opacity = (ringP * 0.28).toFixed(2);
      portalR2.style.opacity = (ringP * 0.18).toFixed(2);
      portalR1.style.transform = 'scale(' + s1 + ') rotate(' + (closestProgress*24) + 'deg)';
      portalR2.style.transform = 'scale(' + s2 + ') rotate(' + (-closestProgress*16) + 'deg)';
    }
  }

  nextArrow.addEventListener('click', function(){
    var target = chapters[currentChapterIdx + 1];
    if(target){ target.scrollIntoView({behavior:'smooth'}); }
  });

  function onScroll(){
    if(!ticking){ window.requestAnimationFrame(update); ticking = true; }
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  window.addEventListener('resize', onScroll);
  update();

  var spotlight = document.getElementById('spotlight');
  window.addEventListener('mousemove', function(e){
    spotlight.style.transform = 'translate(' + e.clientX + 'px,' + e.clientY + 'px)';
  });

  var tiltWrap = document.getElementById('tiltWrap');
  if(tiltWrap){
    var heroSection = document.querySelector('.hero');
    heroSection.addEventListener('mousemove', function(e){
      var r = heroSection.getBoundingClientRect();
      var px = (e.clientX - r.left) / r.width - 0.5;
      var py = (e.clientY - r.top) / r.height - 0.5;
      tiltWrap.style.transform = 'rotateY(' + (px * 10) + 'deg) rotateX(' + (py * -10) + 'deg)';
    });
    heroSection.addEventListener('mouseleave', function(){ tiltWrap.style.transform = 'rotateY(0deg) rotateX(0deg)'; });
  }

  var tiltCards = document.querySelectorAll('.hi-card, .tier-card, .age-card, .reason-cell, .partner-cell, .anecdote-card, .placement-cell, .flow-step');
  tiltCards.forEach(function(card){
    card.addEventListener('mousemove', function(e){
      var r = card.getBoundingClientRect();
      var px = (e.clientX - r.left) / r.width - 0.5;
      var py = (e.clientY - r.top) / r.height - 0.5;
      var isTier = card.classList.contains('tier-card');
      var lift = card.classList.contains('featured') ? -16 : (isTier ? -10 : 0);
      var scale = card.classList.contains('featured') ? 1.03 : (isTier ? 1.015 : 1);
      card.style.transform = 'translateY(' + lift + 'px) scale(' + scale + ') rotateY(' + (px * 7) + 'deg) rotateX(' + (py * -7) + 'deg)';
    });
    card.addEventListener('mouseleave', function(){ card.style.transform = ''; });
  });

  var revealEls = document.querySelectorAll('.reveal');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); } });
  }, {threshold:0.15});
  revealEls.forEach(function(el){ io.observe(el); });

  var ageEls = document.querySelectorAll('.age-card');
  var ageIo = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var card = e.target;
        var pctEl = card.querySelector('.pct');
        var fillEl = card.querySelector('.bar-fill');
        var target = parseInt(pctEl.getAttribute('data-pct'), 10);
        fillEl.style.width = target + '%';
        var cur = 0;
        var step = Math.max(1, Math.round(target/30));
        var t = setInterval(function(){
          cur += step;
          if(cur >= target){ cur = target; clearInterval(t); }
          pctEl.textContent = cur + '%';
        }, 30);
        ageIo.unobserve(card);
      }
    });
  }, {threshold:0.4});
  ageEls.forEach(function(el){ ageIo.observe(el); });

  function formatCount(n, format, pad){
    var s = String(n);
    if(pad){ s = s.padStart(pad, '0'); }
    if(format === 'comma'){ s = n.toLocaleString('en-US'); }
    return s;
  }
  var countEls = document.querySelectorAll('[data-count]');
  var countIo = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var el = e.target;
        var target = parseFloat(el.getAttribute('data-count'));
        var suffix = el.getAttribute('data-suffix') || '';
        var format = el.getAttribute('data-format');
        var pad = parseInt(el.getAttribute('data-pad'), 10) || 0;
        var cur = 0;
        var steps = 36;
        var step = target / steps;
        var t = setInterval(function(){
          cur += step;
          if(cur >= target){ cur = target; clearInterval(t); }
          el.textContent = formatCount(Math.round(cur), format, pad) + suffix;
        }, 28);
        countIo.unobserve(el);
      }
    });
  }, {threshold:0.5});
  countEls.forEach(function(el){ countIo.observe(el); });

  var faqItems = document.querySelectorAll('.faq-item');
  faqItems.forEach(function(item){
    var q = item.querySelector('.faq-q');
    var a = item.querySelector('.faq-a');
    q.addEventListener('click', function(){
      var isOpen = item.classList.contains('open');
      faqItems.forEach(function(other){
        other.classList.remove('open');
        other.querySelector('.faq-a').style.maxHeight = null;
      });
      if(!isOpen){
        item.classList.add('open');
        a.style.maxHeight = a.scrollHeight + 'px';
      }
    });
  });

  var finaleEl = document.getElementById('finale');
  if(finaleEl){
    var finaleText = document.getElementById('finaleText');
    var finaleLogoWrap = document.getElementById('finaleLogoWrap');
    var finalePlayed = false;
    var reducedFinale = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var finaleIo = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting && !finalePlayed){
          finalePlayed = true;
          if(reducedFinale){
            finaleEl.classList.add('curtains-closed');
            finaleLogoWrap.classList.add('show');
            finaleIo.unobserve(finaleEl);
            return;
          }
          finaleEl.classList.add('curtains-closed');
          setTimeout(function(){ finaleText.classList.add('show'); }, 2100);
          setTimeout(function(){ finaleText.classList.remove('show'); finaleText.classList.add('hide'); }, 4600);
          setTimeout(function(){ finaleLogoWrap.classList.add('show'); }, 5500);
          finaleIo.unobserve(finaleEl);
        }
      });
    }, {threshold:0.6});
    finaleIo.observe(finaleEl);
  }

  var timelines = document.querySelectorAll('.timeline');
  var timelineIo = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('in-view'); timelineIo.unobserve(e.target); }
    });
  }, {threshold:0.3});
  timelines.forEach(function(el){ timelineIo.observe(el); });

  var futureRow = document.querySelector('.future-row');
  if(futureRow){
    var futureIo = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ futureRow.classList.add('in-view'); futureIo.unobserve(futureRow); }
      });
    }, {threshold:0.4});
    futureIo.observe(futureRow);
  }

  var interludeWrap = document.getElementById('interludeLines');
  if(interludeWrap){
    var interludeChapter = document.getElementById('interlude');
    var interludeLines = Array.prototype.slice.call(interludeWrap.querySelectorAll('.interlude-line'));
    var interludePlayed = false;
    var interludeIo = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting && !interludePlayed){
          interludePlayed = true;
          interludeChapter.classList.add('in-view');
          var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          function clearInterludeClasses(){
            interludeLines.forEach(function(line){
              line.classList.remove('active','exit','show','hide','stay');
            });
          }
          clearInterludeClasses();
          if(reducedMotion){
            interludeLines[interludeLines.length - 1].classList.add('active');
            interludeIo.unobserve(interludeChapter);
            return;
          }

          var holdMs = 1650;
          var exitMs = 850;
          var gapMs = 220;
          var startDelay = 350;

          function showInterludeLine(index){
            if(index >= interludeLines.length) return;
            var current = interludeLines[index];
            current.classList.remove('exit');
            current.classList.add('active');

            if(index === interludeLines.length - 1) return;

            setTimeout(function(){
              current.classList.remove('active');
              current.classList.add('exit');

              setTimeout(function(){
                current.classList.remove('exit');
                showInterludeLine(index + 1);
              }, exitMs + gapMs);
            }, holdMs);
          }

          setTimeout(function(){ showInterludeLine(0); }, startDelay);
          interludeIo.unobserve(interludeChapter);
        }
      });
    }, {threshold:0.6});
    interludeIo.observe(interludeChapter);
  }
})();
</script>

