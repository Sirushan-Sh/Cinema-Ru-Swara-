.hero-frame-caption .cap-b{font-family:var(--font-mono);font-size:11px;color:var(--ink-dim);}
.hero-frame-badge{
  position:absolute;top:-24px;right:-24px;width:76px;height:76px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, #241019, #0e070a 70%);border:1px solid var(--line-strong);
  display:flex;align-items:center;justify-content:center;box-shadow:0 20px 40px -14px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.08);
